# Projeto Supabase do app
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...   # server-only — NUNCA prefixar com NEXT_PUBLIC

# Opcional: só para aplicar o SQL via `npm run db:apply` (Session pooler URI do Supabase).
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<region>.pooler.supabase.com:5432/postgres

# IA — agendamento por linguagem natural (provider-agnóstico). Chave SÓ no backend,
# NUNCA prefixar com NEXT_PUBLIC. Sem AI_API_KEY, o app cai no fluxo manual.
AI_PROVIDER=openai                 # openai (padrão) ou anthropic
AI_API_KEY=<SUA_CHAVE>             # OpenAI: sk-...  | Anthropic: sk-ant-...
AI_MODEL=gpt-4o-mini              # OpenAI: gpt-4o-mini  | Anthropic: claude-haiku-4-5
AI_MAX_CALLS_PER_DAY=200           # teto diário de chamadas ao LLM
